{
  "name": "evermist",
  "version": "1.0.0",
  "description": "D&D fog-of-war map viewer for TV display",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "set WIN_CSC_LINK=&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win"
  },
  "build": {
    "appId": "com.evermist.app",
    "productName": "Evermist",
    "files": [
      "index.html",
      "lib/pixi.min.js",
      "renderer.js",
      "fog.js",
      "tools.js",
      "sceneStore.js",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "pixi.js": "^7.4.3"
  }
}
