{
  "name": "evermist",
  "version": "1.2.0",
  "description": "D&D fog-of-war map viewer for TV display",
  "main": "main.js",
  "author": "Hinnful",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hinnful/Evermist.git"
  },
  "scripts": {
    "test": "node --test",
    "start": "electron .",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:mac": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.evermist.app",
    "productName": "Evermist",
    "icon": "build/icon.png",
    "artifactName": "${productName}.${ext}",
    "files": [
      "index.html",
      "splash.html",
      "lib/pixi.min.js",
      "renderer.js",
      "state.js",
      "display.js",
      "video.js",
      "scenes.js",
      "viewport.js",
      "backup.js",
      "grid.js",
      "fog.js",
      "tools.js",
      "sceneStore.js",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": "universal"
      },
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    }
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "pixi.js": "^7.4.3"
  }
}
